# ============================================================
# Groundwork Environment Variables
# Copy to .env.local and fill in values: cp .env.example .env.local
# ============================================================

# --- MVP (Sprint 1) ---
# No env vars needed — app uses localStorage

# --- Sprint 2: Turso Database ---
# TURSO_DATABASE_URL=libsql://groundwork-dev-<your-org>.turso.io
# TURSO_AUTH_TOKEN=

# --- Sprint 2: NextAuth ---
# NEXTAUTH_SECRET=           # Generate: openssl rand -base64 32
# NEXTAUTH_URL=http://localhost:3000

# --- Sprint 2: GitHub OAuth ---
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
